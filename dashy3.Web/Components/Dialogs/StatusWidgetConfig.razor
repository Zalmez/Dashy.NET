@* Status widget configuration — add/remove monitored services *@

<div class="mb-4">
    <div class="flex items-center justify-between mb-2">
        <label class="text-sm font-medium text-slate-700 dark:text-slate-300">
            Services to Monitor
            @if (_services.Count == 0)
            {
                <span class="text-red-500 ml-0.5">*</span>
            }
        </label>
        <button type="button"
                class="flex items-center gap-1 px-2.5 py-1 text-xs font-medium rounded-lg bg-blue-600 hover:bg-blue-700 text-white transition-colors"
                @onclick="AddRow">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Add
        </button>
    </div>

    @if (_services.Count == 0)
    {
        <div class="py-6 text-center text-sm text-slate-400 dark:text-slate-500 border-2 border-dashed border-slate-200 dark:border-slate-700 rounded-lg">
            No services yet — click <strong>Add</strong> to start monitoring
        </div>
    }
    else
    {
        <div class="space-y-2">
            @for (var i = 0; i < _services.Count; i++)
            {
                var idx = i;
                <div class="flex gap-2 items-start">
                    <div class="flex-1 min-w-0 grid grid-cols-2 gap-2">
                        <input type="text"
                               class="input-field text-sm"
                               placeholder="Name (e.g. API)"
                               value="@_services[idx].Name"
                               @oninput="e => UpdateName(idx, e.Value?.ToString() ?? string.Empty)" />
                        <input type="url"
                               class="input-field text-sm"
                               placeholder="https://..."
                               value="@_services[idx].Url"
                               @oninput="e => UpdateUrl(idx, e.Value?.ToString() ?? string.Empty)" />
                    </div>
                    <button type="button"
                            class="flex-shrink-0 p-2 text-slate-400 hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-950/30 rounded-lg transition-colors mt-0.5"
                            title="Remove"
                            @onclick="() => RemoveRow(idx)">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    </button>
                </div>
            }
        </div>
    }

    @if (_services.Count == 0)
    {
        <p class="text-xs text-red-500 mt-1">Add at least one service to monitor</p>
    }
</div>

@code {
    public record StatusServiceEntry(string Name, string Url);

    [Parameter] public List<StatusServiceEntry> Services { get; set; } = [];
    [Parameter] public EventCallback<List<StatusServiceEntry>> ServicesChanged { get; set; }

    private List<StatusServiceEntry> _services = [];

    protected override void OnParametersSet()
    {
        // Sync from parent only when the list reference changes (initial load)
        if (_services.Count == 0 && Services.Count > 0)
            _services = [.. Services];
    }

    private void AddRow()
    {
        _services.Add(new StatusServiceEntry("", "https://"));
        Notify();
    }

    private void RemoveRow(int idx)
    {
        _services.RemoveAt(idx);
        Notify();
    }

    private void UpdateName(int idx, string name)
    {
        _services[idx] = _services[idx] with { Name = name };
        Notify();
    }

    private void UpdateUrl(int idx, string url)
    {
        _services[idx] = _services[idx] with { Url = url };
        Notify();
    }

    private void Notify() => ServicesChanged.InvokeAsync([.. _services]);
}
