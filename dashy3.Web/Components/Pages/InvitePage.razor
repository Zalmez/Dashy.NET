@page "/invite/{Token}"
@rendermode InteractiveServer
@layout EmptyLayout
@using dashy3.Web.Services
@inject IAuthService AuthService
@inject NavigationManager Nav
@inject HttpClient Http

<PageTitle>Accept Invite — dashy3</PageTitle>

<div class="min-h-screen bg-[#0e0e10] flex items-center justify-center p-4">
    <div class="w-full max-w-md">
        <!-- Logo / Title -->
        <div class="text-center mb-8">
            <div class="w-16 h-16 bg-[#7c5cbf] rounded-2xl flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z" />
                </svg>
            </div>
            <h1 class="text-2xl font-bold text-white">Join dashy3</h1>
            <p class="text-[#8b8b9e] mt-1 text-sm">You've been invited to create an account</p>
        </div>

        <!-- Content Card -->
        <div class="bg-[#1a1a2e] border border-[#2a2a3e] rounded-2xl p-8">
            @if (_loading)
            {
                <div class="flex justify-center py-8">
                    <div class="animate-spin w-8 h-8 border-2 border-[#7c5cbf] border-t-transparent rounded-full"></div>
                </div>
            }
            else if (_inviteInfo is null || !_inviteInfo.IsValid)
            {
                <div class="text-center py-4">
                    <div class="w-12 h-12 bg-red-500/10 rounded-full flex items-center justify-center mx-auto mb-4">
                        <svg class="w-6 h-6 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z" />
                        </svg>
                    </div>
                    <h2 class="text-lg font-medium text-white mb-2">Invalid or Expired Invite</h2>
                    <p class="text-[#8b8b9e] text-sm mb-6">This invite link is no longer valid. Please contact an administrator for a new invite.</p>
                    <a href="/login" class="text-[#7c5cbf] hover:text-[#8d6dd0] text-sm font-medium">Go to Login</a>
                </div>
            }
            else if (_success)
            {
                <div class="text-center py-4">
                    <div class="w-12 h-12 bg-green-500/10 rounded-full flex items-center justify-center mx-auto mb-4">
                        <svg class="w-6 h-6 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                    </div>
                    <h2 class="text-lg font-medium text-white mb-2">Account Created!</h2>
                    <p class="text-[#8b8b9e] text-sm mb-6">Your account has been created successfully. You can now sign in.</p>
                    <a href="/login" class="inline-block bg-[#7c5cbf] hover:bg-[#8d6dd0] text-white font-medium py-2.5 px-6 rounded-lg transition-colors text-sm">
                        Sign In
                    </a>
                </div>
            }
            else
            {
                @if (!string.IsNullOrEmpty(_error))
                {
                    <div class="mb-4 p-3 bg-red-500/10 border border-red-500/30 rounded-lg text-sm">
                        <div class="flex items-start gap-2">
                            <svg class="w-4 h-4 text-red-400 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z" />
                            </svg>
                            <span class="text-red-400">@_error</span>
                        </div>
                    </div>
                }

                <div class="mb-6 p-4 bg-[#0e0e10] rounded-lg border border-[#2a2a3e]">
                    <div class="text-sm text-[#8b8b9e] mb-1">Invite for</div>
                    <div class="text-white font-medium">@_inviteInfo.Email</div>
                    <div class="text-xs text-[#8b8b9e] mt-2">
                        Role: <span class="text-[#7c5cbf]">@_inviteInfo.Role</span>
                    </div>
                </div>

                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-[#b0b0c3] mb-1.5">Display Name</label>
                        <input @bind="_displayName"
                               @bind:event="oninput"
                               type="text"
                               placeholder="Your name"
                               @onkeydown="HandleKeyDown"
                               class="w-full bg-[#0e0e10] border border-[#2a2a3e] rounded-lg px-3 py-2.5 text-white placeholder-[#4a4a5e] focus:outline-none focus:border-[#7c5cbf] focus:ring-1 focus:ring-[#7c5cbf] text-sm" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-[#b0b0c3] mb-1.5">Password</label>
                        <input @bind="_password"
                               @bind:event="oninput"
                               type="password"
                               placeholder="Choose a password (min 8 characters)"
                               @onkeydown="HandleKeyDown"
                               class="w-full bg-[#0e0e10] border border-[#2a2a3e] rounded-lg px-3 py-2.5 text-white placeholder-[#4a4a5e] focus:outline-none focus:border-[#7c5cbf] focus:ring-1 focus:ring-[#7c5cbf] text-sm" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-[#b0b0c3] mb-1.5">Confirm Password</label>
                        <input @bind="_confirmPassword"
                               @bind:event="oninput"
                               type="password"
                               placeholder="Confirm your password"
                               @onkeydown="HandleKeyDown"
                               class="w-full bg-[#0e0e10] border border-[#2a2a3e] rounded-lg px-3 py-2.5 text-white placeholder-[#4a4a5e] focus:outline-none focus:border-[#7c5cbf] focus:ring-1 focus:ring-[#7c5cbf] text-sm" />
                    </div>
                </div>

                <button @onclick="HandleAccept"
                        disabled="@_submitting"
                        class="w-full mt-6 bg-[#7c5cbf] hover:bg-[#8d6dd0] disabled:opacity-50 disabled:cursor-not-allowed text-white font-medium py-2.5 px-4 rounded-lg transition-colors text-sm">
                    @if (_submitting)
                    {
                        <span>Creating account...</span>
                    }
                    else
                    {
                        <span>Create Account</span>
                    }
                </button>

                <p class="mt-4 text-center text-sm text-[#8b8b9e]">
                    Already have an account? <a href="/login" class="text-[#7c5cbf] hover:text-[#8d6dd0]">Sign in</a>
                </p>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public string Token { get; set; } = "";

    private InviteInfoDto? _inviteInfo;
    private bool _loading = true;
    private bool _submitting;
    private bool _success;
    private string? _error;
    private string _displayName = "";
    private string _password = "";
    private string _confirmPassword = "";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await Http.GetAsync($"/api/auth/invite/{Token}");
            if (response.IsSuccessStatusCode)
            {
                _inviteInfo = await response.Content.ReadFromJsonAsync<InviteInfoDto>();
            }
        }
        catch
        {
            _inviteInfo = null;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task HandleAccept()
    {
        _error = null;

        if (string.IsNullOrWhiteSpace(_displayName))
        {
            _error = "Please enter your name.";
            return;
        }

        if (_password.Length < 8)
        {
            _error = "Password must be at least 8 characters.";
            return;
        }

        if (_password != _confirmPassword)
        {
            _error = "Passwords do not match.";
            return;
        }

        _submitting = true;
        try
        {
            var response = await Http.PostAsJsonAsync($"/api/auth/invite/{Token}/accept", new
            {
                DisplayName = _displayName,
                Password = _password
            });

            if (response.IsSuccessStatusCode)
            {
                _success = true;
            }
            else
            {
                var error = await response.Content.ReadFromJsonAsync<ErrorResponse>();
                _error = error?.Error ?? "Failed to create account. Please try again.";
            }
        }
        catch
        {
            _error = "An error occurred. Please try again.";
        }
        finally
        {
            _submitting = false;
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !_submitting)
        {
            await HandleAccept();
        }
    }

    private record InviteInfoDto(string Email, string Role, DateTime ExpiresAt, bool IsValid);
    private record ErrorResponse(string? Error);
}
