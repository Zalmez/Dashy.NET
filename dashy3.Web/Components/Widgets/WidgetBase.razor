@inject IDashboardService DashboardService
@inject IToastService Toast
@inject IJSRuntime JS

<div class="@GetContainerClass() relative"
     draggable="true"
     @ref="_containerRef"
     @ondragstart="OnDragStart"
     @ondragstart:stopPropagation="true"
     @ondragend="OnDragEnd"
     @ondragover="OnDragOver"
     @ondragover:preventDefault="true"
     @ondragover:stopPropagation="true"
     @ondrop="OnDrop"
     @ondrop:stopPropagation="true"
     @ondragenter="OnDragEnter"
     @ondragenter:stopPropagation="true"
     @ondragleave="OnDragLeave"
     @ondragleave:stopPropagation="true">

    @* Drop position indicator - left side (drop before) *@
    @if (_isDragOver && _dropPosition == DropPosition.Before)
    {
        <div class="absolute left-0 top-0 bottom-0 w-1 bg-blue-500 rounded-full z-10 -translate-x-2 animate-pulse"></div>
    }

    @* Drop position indicator - right side (drop after) *@
    @if (_isDragOver && _dropPosition == DropPosition.After)
    {
        <div class="absolute right-0 top-0 bottom-0 w-1 bg-blue-500 rounded-full z-10 translate-x-2 animate-pulse"></div>
    }

    @* Drop position indicator - bottom (drop after, for stacking) *@
    @if (_isDragOver && _dropPosition == DropPosition.Below)
    {
        <div class="absolute left-0 right-0 bottom-0 h-1 bg-blue-500 rounded-full z-10 translate-y-2 animate-pulse"></div>
    }

    <div class="@GetCardClass()"
         @onmouseenter="() => _isHovered = true"
         @onmouseleave="() => _isHovered = false">

        <!-- Widget Header -->
        <div class="@GetHeaderClass()">
            <div class="flex items-center @(ShowContainer ? "gap-3 flex-1 min-w-0" : "gap-1")">
                <!-- Drag handle -->
                <span class="cursor-grab active:cursor-grabbing text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-200 transition-colors select-none"
                      onmousedown="dragDropInterop.activateDragHandle()"
                      onmouseup="dragDropInterop.deactivateDragHandle()"
                      onmouseleave="dragDropInterop.deactivateDragHandle()">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="5" r="1" fill="currentColor"/><circle cx="9" cy="12" r="1" fill="currentColor"/><circle cx="9" cy="19" r="1" fill="currentColor"/><circle cx="15" cy="5" r="1" fill="currentColor"/><circle cx="15" cy="12" r="1" fill="currentColor"/><circle cx="15" cy="19" r="1" fill="currentColor"/></svg>
                </span>
                @if (ShowContainer)
                {
                    <!-- Title (no icon) -->
                    <h3 class="font-semibold text-slate-900 dark:text-white truncate text-sm">@Widget.Title</h3>
                }
            </div>

            <div class="flex items-center @(ShowContainer ? "gap-2" : "gap-0.5")">
                @if (Widget.IsBeingEdited)
                {
                    <span class="inline-flex items-center gap-1 px-2 py-0.5 text-xs rounded-full border border-orange-500 text-orange-600 dark:text-orange-400">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                        @Widget.EditedBy
                    </span>
                }

                <!-- Actions menu -->
                <div class="relative">
                    <button class="@GetMenuButtonClass()"
                            @onclick="ToggleMenu">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="5" r="1" fill="currentColor"/><circle cx="12" cy="12" r="1" fill="currentColor"/><circle cx="12" cy="19" r="1" fill="currentColor"/></svg>
                    </button>

                    @if (_menuOpen)
                    {
                        <div class="absolute right-0 top-full mt-1 w-44 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 rounded-lg shadow-lg z-50 py-1">
                            <p class="text-xs font-medium text-slate-500 dark:text-slate-400 px-3 py-1.5">Widget Actions</p>
                            <div class="h-px bg-slate-200 dark:bg-slate-700 my-1"></div>
                            @if (Widget.Type == WidgetType.Api)
                            {
                                <button class="w-full flex items-center gap-2 px-3 py-2 text-sm text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
                                        @onclick="CopyApiWidgetIdAsync">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                                    @(_menuIdCopied ? "Copied!" : "Copy Widget ID")
                                </button>
                                <div class="h-px bg-slate-200 dark:bg-slate-700 my-1"></div>
                            }
                            <button class="w-full flex items-center gap-2 px-3 py-2 text-sm text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
                                    @onclick="ToggleEdit">
                                @if (Widget.IsBeingEdited)
                                {
                                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                                    <span>Stop Editing</span>
                                }
                                else
                                {
                                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                    <span>Edit Widget</span>
                                }
                            </button>
                            <div class="h-px bg-slate-200 dark:bg-slate-700 my-1"></div>
                            <p class="text-xs font-medium text-slate-500 dark:text-slate-400 px-3 py-1.5">Size</p>
                            <button class="w-full text-left px-3 py-2 text-sm text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
                                    @onclick='() => SetSize(WidgetSize.Small)'>Small</button>
                            <button class="w-full text-left px-3 py-2 text-sm text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
                                    @onclick='() => SetSize(WidgetSize.Medium)'>Medium</button>
                            <button class="w-full text-left px-3 py-2 text-sm text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
                                    @onclick='() => SetSize(WidgetSize.Large)'>Large</button>
                            @if (Widget.ParentWidgetId is not null)
                            {
                                <div class="h-px bg-slate-200 dark:bg-slate-700 my-1"></div>
                                <button class="w-full flex items-center gap-2 px-3 py-2 text-sm text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
                                        @onclick="RemoveFromSection">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="12" y1="11" x2="12" y2="17"/><path d="M9 11l6 6"/><path d="M15 11l-6 6"/></svg>
                                    Remove from Section
                                </button>
                            }
                            <div class="h-px bg-slate-200 dark:bg-slate-700 my-1"></div>
                            <button class="w-full flex items-center gap-2 px-3 py-2 text-sm text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-950 transition-colors"
                                    @onclick="Delete">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3,6 5,6 21,6"/><path d="M19,6l-1,14a2,2,0,0,1-2,2H8a2,2,0,0,1-2-2L5,6"/><path d="M10,11v6"/><path d="M14,11v6"/><path d="M9,6V4a1,1,0,0,1,1-1h4a1,1,0,0,1,1,1V6"/></svg>
                                Delete Widget
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Widget Content -->
        <div class="@GetContentClass()">
            @ChildContent
        </div>
    </div>
</div>

<EditWidgetDialog Widget="_editingWidget" OnSaved="CloseEditDialog" />

@code {
    [Parameter, EditorRequired] public Widget Widget { get; set; } = default!;
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public EventCallback<string> OnDragDropReorder { get; set; }

    private ElementReference _containerRef;
    private bool _isHovered;
    private bool _isDragOver;
    private DropPosition _dropPosition = DropPosition.None;
    private bool _menuOpen;
    private bool _menuIdCopied;
    private Widget? _editingWidget;

    private bool ShowContainer =>
        WidgetType.All.FirstOrDefault(t => t.Type == Widget.Type)?.ShowContainer ?? true;

    private enum DropPosition { None, Before, After, Below }

    private void OnDragEnd()
    {
        // Clear drag state in JS when drag ends
        _ = JS.InvokeVoidAsync("dragDropInterop.clearDragState");
    }

    private string GetContainerClass() => string.Join(" ", new[]
    {
        GetSizeClass(),
        _isDragOver ? "widget-drag-over" : "",
        Widget.IsBeingEdited ? "" : ""
    }.Where(s => !string.IsNullOrEmpty(s)));

    private string GetCardClass()
    {
        if (!ShowContainer)
            return "flex flex-col relative transition-all duration-200";

        return $"h-full bg-white dark:bg-slate-800 rounded-xl flex flex-col shadow-sm hover:shadow-md transition-all duration-200 {GetBorderClass()}";
    }

    private string GetHeaderClass()
    {
        if (!ShowContainer)
            return $"absolute top-1 right-1 z-10 flex items-center justify-end gap-1 px-1.5 py-1 rounded-xl bg-white/80 dark:bg-slate-800/80 backdrop-blur-sm shadow-md border border-slate-200/60 dark:border-slate-700/60 transition-opacity {(_isHovered || Widget.IsBeingEdited ? "opacity-100" : "opacity-0")}";

        return "flex items-center justify-between px-4 py-3 border-b border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900/50 rounded-t-xl";
    }

    private string GetContentClass() =>
        ShowContainer ? "flex-1 p-4 overflow-auto min-h-0" : "";

    // Containerless: opacity handled by pill wrapper — button just needs hover highlight
    // Container: button fades in on hover and shows hover bg
    private string GetMenuButtonClass()
    {
        const string base_ = "p-1 rounded-lg text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-200 transition-all";
        if (!ShowContainer)
            return base_;
        var visible = _isHovered || Widget.IsBeingEdited ? "opacity-100" : "opacity-0";
        return $"{base_} hover:bg-slate-100 dark:hover:bg-slate-700 {visible}";
    }

    private string GetSizeClass()
    {
        // Containerless widgets are content-driven — no fixed height, just column span
        if (!ShowContainer) return Widget.Size switch
        {
            WidgetSize.Large => "col-span-1 md:col-span-2",
            _                => "col-span-1"
        };

        return Widget.Size switch
        {
            WidgetSize.Small  => "h-[180px] col-span-1",
            WidgetSize.Large  => "h-[500px] col-span-1 md:col-span-2",
            _                 => "h-[340px] col-span-1"  // Medium
        };
    }

    private string GetBorderClass()
    {
        if (Widget.IsBeingEdited)
            return "border-2 border-orange-500 shadow-lg shadow-orange-500/20";

        if (_isDragOver)
            return "border-2 border-blue-400 dark:border-blue-500 shadow-lg shadow-blue-500/20";

        return "border-2 border-slate-200 dark:border-slate-700 hover:border-slate-300 dark:hover:border-slate-600";
    }

    private void ToggleMenu()
    {
        _menuOpen = !_menuOpen;
    }

    private async Task CopyApiWidgetIdAsync()
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", Widget.Id);
        _menuIdCopied = true;
        StateHasChanged();
        await Task.Delay(2000);
        _menuIdCopied = false;
        StateHasChanged();
    }

    private void ToggleEdit()
    {
        if (!Widget.IsBeingEdited)
        {
            _editingWidget = Widget;
            _menuOpen = false;
        }
        else
        {
            DashboardService.ToggleWidgetEdit(Widget.Id);
            _menuOpen = false;
        }
    }

    private void CloseEditDialog()
    {
        _editingWidget = null;
    }

    private async Task SetSize(WidgetSize size)
    {
        Widget.Size = size;
        await DashboardService.SaveWidgetAsync(Widget);
        _menuOpen = false;
    }

    private async Task Delete()
    {
        await DashboardService.DeleteWidgetAsync(Widget.Id);
        Toast.ShowSuccess("Widget deleted successfully!");
        _menuOpen = false;
    }

    private async Task RemoveFromSection()
    {
        await DashboardService.MoveWidgetToSectionAsync(Widget.Id, null);
        Toast.ShowSuccess("Widget moved to top level");
        _menuOpen = false;
    }

    private async Task OnDragStart(DragEventArgs e)
    {
        // Check if drag was initiated from the handle (via JS)
        var allowed = await JS.InvokeAsync<bool>("dragDropInterop.onDragStart", Widget.Id);
        if (!allowed)
        {
            // Drag was not started from handle - we can't cancel it in Blazor,
            // but we don't set the widget ID, so drop handlers will ignore it
            return;
        }
    }

    private async Task OnDragEnter()
    {
        var draggedId = await JS.InvokeAsync<string?>("dragDropInterop.getDraggedWidgetId");
        if (!string.IsNullOrEmpty(draggedId) && draggedId != Widget.Id)
        {
            _isDragOver = true;
        }
    }

    private void OnDragLeave()
    {
        _isDragOver = false;
        _dropPosition = DropPosition.None;
    }

    private async Task OnDragOver(DragEventArgs e)
    {
        // Determine drop position based on mouse position relative to element
        try
        {
            var rect = await JS.InvokeAsync<BoundingClientRect>("dragDropInterop.getBoundingRect", _containerRef);

            // Calculate relative position within the widget
            var relativeX = (e.ClientX - rect.Left) / rect.Width;  // 0 to 1
            var relativeY = (e.ClientY - rect.Top) / rect.Height;  // 0 to 1

            // If cursor is in the bottom 25% of the widget, show bottom indicator
            if (relativeY > 0.75)
            {
                _dropPosition = DropPosition.Below;
            }
            // Otherwise use left/right based on X position
            else
            {
                _dropPosition = relativeX < 0.5 ? DropPosition.Before : DropPosition.After;
            }
        }
        catch
        {
            _dropPosition = DropPosition.After;
        }
    }

    private async Task OnDrop()
    {
        var dropPos = _dropPosition;
        _isDragOver = false;
        _dropPosition = DropPosition.None;

        var draggedId = await JS.InvokeAsync<string?>("dragDropInterop.getDraggedWidgetId");
        await JS.InvokeVoidAsync("dragDropInterop.clearDragState");

        if (!string.IsNullOrEmpty(draggedId) && draggedId != Widget.Id)
        {
            // Both After and Below mean "insert after this widget"
            var insertBefore = dropPos == DropPosition.Before;
            await DashboardService.ReorderWidgetsAsync(draggedId, Widget.Id, insertBefore);
        }
    }

    // Record for JS interop
    private record BoundingClientRect(double Left, double Top, double Width, double Height);
}
