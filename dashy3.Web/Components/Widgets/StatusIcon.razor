@switch (Status)
{
    case "online":
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 @CssColor" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22,4 12,14.01 9,11.01"/></svg>
        break;
    case "warning":
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 @CssColor" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        break;
    case "offline":
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 @CssColor" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
        break;
    default:
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 @CssColor" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22,12 18,12 15,21 9,3 6,12 2,12"/></svg>
        break;
}

@code {
    [Parameter] public string Status { get; set; } = "online";
    [Parameter] public string CssColor { get; set; } = "text-slate-500";
}
