@* CVE Tracker Widget - displays security vulnerabilities from NVD or EUVD *@
@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="h-full flex flex-col gap-4">
    <!-- Header with source and refresh -->
    <div class="flex items-center justify-between gap-2 flex-shrink-0">
        <div class="flex items-center gap-2">
            <span class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wide">@_source</span>
            @if (_cves.Count > 0)
            {
                <span class="px-1.5 py-0.5 text-xs rounded bg-slate-200 dark:bg-slate-700 text-slate-600 dark:text-slate-300">@_cves.Count</span>
            }
        </div>
        <button @onclick="RefreshAsync"
                disabled="@_loading"
                title="Refresh CVEs"
                class="flex-shrink-0 p-1 rounded-lg text-slate-400 hover:text-slate-600 dark:hover:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors disabled:opacity-50">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 @(_loading ? "animate-spin" : "")" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="23,4 23,10 17,10"/><polyline points="1,20 1,14 7,14"/>
                <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/>
            </svg>
        </button>
    </div>

    @if (_loading && _cves.Count == 0)
    {
        <div class="flex-1 flex items-center justify-center">
            <div class="flex items-center gap-2 text-slate-400">
                <svg class="animate-spin w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                </svg>
                <span class="text-sm">Loading CVEs...</span>
            </div>
        </div>
    }
    else if (_error is not null)
    {
        <div class="flex-1 flex flex-col items-center justify-center text-center px-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-red-400 mb-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <p class="text-sm text-red-500">@_error</p>
            <button @onclick="RefreshAsync" class="mt-2 text-xs text-blue-500 hover:text-blue-600">Try again</button>
        </div>
    }
    else if (_cves.Count == 0)
    {
        <div class="flex-1 flex flex-col items-center justify-center text-center px-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-green-500 mb-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9,12 11,14 15,10"/></svg>
            <p class="text-sm text-slate-500 dark:text-slate-400">No high/critical CVEs found in the last 7 days.</p>
        </div>
    }
    else
    {
        <!-- CVE List -->
        <div id="cve-scroll-@Widget.Id" class="flex-1 @(_autoScroll ? "overflow-hidden" : "overflow-auto") space-y-3">
            @foreach (var cve in _cves)
            {
                var (bgClass, badgeClass, borderClass) = GetSeverityClasses(cve.Severity);
                <a href="@cve.Url" target="_blank" rel="noopener noreferrer"
                   class="block @bgClass rounded-lg p-3 border @borderClass hover:opacity-90 transition-opacity group">
                    <div class="flex items-start justify-between gap-2 mb-2">
                        <div class="flex items-center gap-2 flex-wrap">
                            <span class="px-2 py-0.5 text-xs rounded font-medium @badgeClass">@cve.Severity.ToUpper()</span>
                            <span class="px-1.5 py-0.5 text-xs rounded bg-slate-200 dark:bg-slate-700 text-slate-700 dark:text-slate-300 font-mono">@cve.Score.ToString("0.0")</span>
                            <span class="font-mono text-sm font-medium text-slate-900 dark:text-white">@cve.Id</span>
                        </div>
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-slate-400 group-hover:text-slate-600 dark:group-hover:text-slate-300 flex-shrink-0 opacity-0 group-hover:opacity-100 transition-opacity" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15,3 21,3 21,9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                    </div>
                    <p class="text-sm text-slate-700 dark:text-slate-300 mb-2">@cve.Description</p>
                    @if (cve.AffectedProducts.Length > 0)
                    {
                        <div class="flex flex-wrap gap-1 mb-2">
                            @foreach (var product in cve.AffectedProducts)
                            {
                                <span class="px-1.5 py-0.5 text-xs rounded bg-slate-200 dark:bg-slate-600 text-slate-600 dark:text-slate-300">@product</span>
                            }
                        </div>
                    }
                    <div class="flex items-center justify-end text-xs text-slate-500 dark:text-slate-400">
                        <span>@cve.PublishedDate</span>
                    </div>
                </a>
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public Widget Widget { get; set; } = default!;

    private bool _loading;
    private string? _error;
    private string _source = "NVD";
    private List<CveItem> _cves = [];
    private string _lastSource = "";
    private int _lastLimit = -1;
    private string _lastKeywords = "";
    private bool _autoScroll;
    private bool _scrollStarted;
    private readonly CancellationTokenSource _refreshCts = new();

    protected override void OnInitialized()
    {
        _ = AutoRefreshLoopAsync(_refreshCts.Token);
    }

    protected override async Task OnParametersSetAsync()
    {
        var source = Widget.GetConfig("source", "nvd").ToLowerInvariant();
        var limit = Widget.GetConfig("limit", 10);
        var keywords = Widget.GetConfig("keywords", "");
        _source = source == "euvd" ? "EUVD" : "NVD";
        _autoScroll = Widget.GetConfig("autoScroll", false);

        // Only re-fetch when the source, limit, or keywords actually changed
        if (source != _lastSource || limit != _lastLimit || keywords != _lastKeywords)
        {
            _lastSource = source;
            _lastLimit = limit;
            _lastKeywords = keywords;
            _scrollStarted = false;
            await StopScrollAsync();
            await LoadCvesAsync();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_autoScroll && !_scrollStarted && _cves.Count > 0)
        {
            _scrollStarted = true;
            var speed = Widget.GetConfig("scrollSpeed", "medium") switch
            {
                "slow" => 20.0,
                "fast" => 80.0,
                _      => 40.0
            };
            await JS.InvokeVoidAsync("cveAutoScroll.start", Widget.Id, speed);
        }
        else if (!_autoScroll && _scrollStarted)
        {
            _scrollStarted = false;
            await StopScrollAsync();
        }
    }

    private async Task LoadCvesAsync()
    {
        _loading = true;
        _error = null;
        _scrollStarted = false;
        StateHasChanged();

        try
        {
            var client = HttpClientFactory.CreateClient("dashboards-api");
            var limit = Widget.GetConfig("limit", 10);
            var keywords = Widget.GetConfig("keywords", "");
            var endpoint = _source == "EUVD" ? "/api/cve/euvd" : "/api/cve/nvd";
            var queryParams = $"?limit={limit}";
            if (!string.IsNullOrWhiteSpace(keywords))
                queryParams += $"&keywords={Uri.EscapeDataString(keywords)}";
            var response = await client.GetFromJsonAsync<CveResponse>($"{endpoint}{queryParams}");

            if (response?.Items is not null)
            {
                _cves = response.Items
                    .Select(i => new CveItem(i.Id, i.Severity, i.Score, i.Description, i.PublishedDate, i.Url, i.AffectedProducts ?? []))
                    .ToList();
            }
            else
            {
                _cves = [];
            }
        }
        catch (Exception ex)
        {
            _error = $"Failed to load CVEs: {ex.Message}";
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task RefreshAsync()
    {
        _scrollStarted = false;
        await StopScrollAsync();
        await LoadCvesAsync();
    }

    private async Task AutoRefreshLoopAsync(CancellationToken ct)
    {
        try
        {
            while (!ct.IsCancellationRequested)
            {
                await Task.Delay(TimeSpan.FromMinutes(15), ct);
                await LoadCvesAsync();
            }
        }
        catch (TaskCanceledException) { }
    }

    private async Task StopScrollAsync()
    {
        try { await JS.InvokeVoidAsync("cveAutoScroll.stop", Widget.Id); }
        catch { /* JS may not be available yet */ }
    }

    public async ValueTask DisposeAsync()
    {
        await _refreshCts.CancelAsync();
        await StopScrollAsync();
    }

    private static (string bg, string badge, string border) GetSeverityClasses(string severity) => severity switch
    {
        "critical" => ("bg-red-50 dark:bg-red-950/30",      "bg-red-500 text-white",    "border-red-500"),
        "high"     => ("bg-orange-50 dark:bg-orange-950/30","bg-orange-500 text-white", "border-orange-500"),
        "medium"   => ("bg-yellow-50 dark:bg-yellow-950/30","bg-yellow-500 text-white", "border-yellow-500"),
        "low"      => ("bg-blue-50 dark:bg-blue-950/30",    "bg-blue-500 text-white",   "border-blue-500"),
        _          => ("bg-slate-50 dark:bg-slate-900",     "bg-slate-500 text-white",  "border-slate-500"),
    };

    private record CveItem(string Id, string Severity, double Score, string Description, string PublishedDate, string Url, string[] AffectedProducts);
    private record CveResponse(string Source, CveResponseItem[] Items);
    private record CveResponseItem(string Id, string Severity, double Score, string Description, string PublishedDate, string Url, string[]? AffectedProducts);
}
