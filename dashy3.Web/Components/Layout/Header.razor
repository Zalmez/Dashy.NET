@inject IDashboardService DashboardService
@inject IThemeService ThemeService
@inject IJSRuntime JS
@rendermode InteractiveServer
@implements IDisposable

<header class="h-16 bg-white dark:bg-slate-900 border-b border-slate-200 dark:border-slate-800 flex items-center justify-between px-6 flex-shrink-0">
    <!-- Left: Dashboard title -->
    <div>
        <h1 class="text-xl font-semibold text-slate-900 dark:text-white">
            @(DashboardService.ActiveDashboard?.Name ?? "Dashboard")
        </h1>
        <p class="text-sm text-slate-500 dark:text-slate-400">Welcome back! Here's your overview</p>
    </div>

    <!-- Right: Actions -->
    <div class="flex items-center gap-3">
        <!-- Share Button (owner or editor) -->
        @if (_canShare)
        {
            <button class="flex items-center gap-2 px-3 py-1.5 text-sm rounded-lg bg-blue-600 hover:bg-blue-700 text-white transition-colors"
                    @onclick="OpenShareDialog">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                </svg>
                Share
            </button>
        }
        <!-- Quick Settings -->
        <button class="flex items-center gap-2 px-3 py-1.5 text-sm rounded-lg border border-slate-200 dark:border-slate-700 text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
                @onclick="OpenSettings">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
            Dashboard Settings
        </button>

        <!-- Layout Mode Dropdown -->
        <div class="relative">
            <button class="flex items-center gap-2 px-3 py-1.5 text-sm rounded-lg border border-slate-200 dark:border-slate-700 text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
                    @onclick="ToggleLayoutMenu">
                @LayoutModeIcon(DashboardService.ActiveDashboard?.LayoutMode ?? LayoutMode.Auto)
                Layout
            </button>
            @if (_showLayoutMenu)
            {
                <div class="absolute right-0 top-full mt-1 w-44 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 rounded-lg shadow-lg z-50">
                    <div class="p-1">
                        <p class="text-xs font-medium text-slate-500 dark:text-slate-400 px-3 py-1.5">Layout Mode</p>
                        <button class="w-full flex items-center gap-2 px-3 py-2 text-sm text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-md transition-colors"
                                @onclick='() => SetLayout(LayoutMode.Auto)'>
                            @LayoutModeIcon(LayoutMode.Auto) Auto Grid
                        </button>
                        <button class="w-full flex items-center gap-2 px-3 py-2 text-sm text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-md transition-colors"
                                @onclick='() => SetLayout(LayoutMode.Horizontal)'>
                            @LayoutModeIcon(LayoutMode.Horizontal) Horizontal
                        </button>
                        <button class="w-full flex items-center gap-2 px-3 py-2 text-sm text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-md transition-colors"
                                @onclick='() => SetLayout(LayoutMode.Vertical)'>
                            @LayoutModeIcon(LayoutMode.Vertical) Vertical
                        </button>
                    </div>
                </div>
            }
        </div>

        @* Notification bell disabled for now
        <button class="relative p-2 rounded-lg border border-slate-200 dark:border-slate-700 text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
            <span class="absolute -top-1 -right-1 w-5 h-5 bg-blue-500 text-white text-xs rounded-full flex items-center justify-center">3</span>
        </button>
        *@

        <!-- Theme Toggle -->
        <button class="p-2 rounded-lg border border-slate-200 dark:border-slate-700 text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
                @onclick="ToggleTheme"
                title="@(ThemeService.IsDarkMode ? "Switch to light mode" : "Switch to dark mode")">
            @if (ThemeService.IsDarkMode)
            {
                <!-- Sun icon -->
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
            }
            else
            {
                <!-- Moon icon -->
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
            }
        </button>
    </div>
</header>

<!-- Quick Settings Panel -->
<QuickSettingsPanel IsOpen="_settingsOpen" OnClose="CloseSettings" />

<!-- Share Dashboard Dialog -->
<ShareDashboardDialog IsOpen="_shareDialogOpen"
                      Dashboard="DashboardService.ActiveDashboard"
                      OnClose="() => _shareDialogOpen = false" />

@code {
    private bool _showLayoutMenu;
    private bool _settingsOpen;
    private bool _shareDialogOpen;

    private bool _canShare =>
        DashboardService.ActiveDashboard?.UserPermission == "Owner" ||
        DashboardService.ActiveDashboard?.UserPermission == "Editor";

    protected override void OnInitialized()
    {
        DashboardService.StateChanged += OnStateChanged;
        ThemeService.ThemeChanged += OnStateChanged;
    }

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    private void OpenShareDialog() => _shareDialogOpen = true;

    private void ToggleLayoutMenu() => _showLayoutMenu = !_showLayoutMenu;

    private async Task SetLayout(LayoutMode mode)
    {
        await DashboardService.SetDashboardLayoutAsync(DashboardService.ActiveDashboardId, mode);
        _showLayoutMenu = false;
    }

    private async Task ToggleTheme()
    {
        ThemeService.ToggleTheme();
        await JS.InvokeVoidAsync("themeInterop.setDarkMode", ThemeService.IsDarkMode);
    }

    private void OpenSettings() => _settingsOpen = true;
    private void CloseSettings() => _settingsOpen = false;

    private RenderFragment LayoutModeIcon(LayoutMode mode) => mode switch
    {
        LayoutMode.Horizontal => @<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>,
        LayoutMode.Vertical => @<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="2" x2="12" y2="22"/><path d="M4.93 4.93l14.14 14.14"/></svg>,
        _ => @<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
    };

    public void Dispose()
    {
        DashboardService.StateChanged -= OnStateChanged;
        ThemeService.ThemeChanged -= OnStateChanged;
    }
}
