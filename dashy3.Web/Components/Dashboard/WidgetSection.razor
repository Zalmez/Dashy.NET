@* WidgetSection - a collapsible section widget containing child widgets *@
@inject IJSRuntime JS
@inject IToastService Toast

<div class="mb-8 rounded-xl border-2 transition-all duration-200 @GetContainerClass()"
     draggable="true"
     @ondragstart="OnDragStart"
     @ondragend="OnDragEnd"
     @ondragover:preventDefault="true"
     @ondrop="OnDrop"
     @ondragenter="OnDragEnter"
     @ondragleave="OnDragLeave"
     @onmouseenter="() => _isHovered = true"
     @onmouseleave="() => _isHovered = false">

    <!-- Section header -->
    <div class="flex items-center gap-3 p-4 bg-slate-50 dark:bg-slate-900/50 rounded-t-xl border-b border-slate-200 dark:border-slate-700">
        <!-- Drag handle - only this enables dragging (via JS) -->
        <span class="cursor-grab active:cursor-grabbing text-slate-400 hover:text-slate-600 dark:hover:text-slate-300 transition-opacity select-none @(_isHovered ? "opacity-100" : "opacity-0")"
              onmousedown="dragDropInterop.activateDragHandle()"
              onmouseup="dragDropInterop.deactivateDragHandle()"
              onmouseleave="dragDropInterop.deactivateDragHandle()">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="5" r="1" fill="currentColor"/><circle cx="9" cy="12" r="1" fill="currentColor"/><circle cx="9" cy="19" r="1" fill="currentColor"/><circle cx="15" cy="5" r="1" fill="currentColor"/><circle cx="15" cy="12" r="1" fill="currentColor"/><circle cx="15" cy="19" r="1" fill="currentColor"/></svg>
        </span>

        <button class="flex items-center gap-2 group"
                @onclick="ToggleCollapse">
            <svg xmlns="http://www.w3.org/2000/svg"
                 class="w-4 h-4 text-slate-500 transition-transform @(IsCollapsed ? "-rotate-90" : "")"
                 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="6,9 12,15 18,9"/>
            </svg>
        </button>

        @if (_renaming)
        {
            <input @ref="_renameInput"
                   class="text-lg font-bold bg-transparent border-b-2 border-blue-500 outline-none text-slate-900 dark:text-white min-w-0 flex-shrink"
                   style="width: @(Math.Max(_renameValue.Length, 4))ch"
                   @bind="_renameValue"
                   @bind:event="oninput"
                   @onkeydown="OnRenameKeyDown"
                   @onblur="CommitRename"
                   @onclick:stopPropagation="true" />
        }
        else
        {
            <h2 class="text-lg font-bold text-slate-900 dark:text-white hover:text-blue-500 transition-colors cursor-pointer select-none"
                @ondblclick="StartRename"
                @ondblclick:stopPropagation="true"
                title="Double-click to rename">
                @SectionWidget.Title
            </h2>
        }
        <div class="flex-1 h-px bg-slate-200 dark:bg-slate-700"></div>
        <span class="text-xs text-slate-500 dark:text-slate-400">@ChildWidgets.Count() widget@(ChildWidgets.Count() != 1 ? "s" : "")</span>

        <!-- Section actions menu -->
        <div class="relative">
            <button class="p-1 rounded-lg text-slate-400 hover:text-slate-600 dark:hover:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-700 transition-all @(_isHovered ? "opacity-100" : "opacity-0")"
                    @onclick="ToggleMenu" @onclick:stopPropagation="true">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="5" r="1" fill="currentColor"/><circle cx="12" cy="12" r="1" fill="currentColor"/><circle cx="12" cy="19" r="1" fill="currentColor"/></svg>
            </button>

            @if (_menuOpen)
            {
                <div class="absolute right-0 top-full mt-1 w-44 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 rounded-lg shadow-lg z-50 py-1">
                    <button class="w-full flex items-center gap-2 px-3 py-2 text-sm text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
                            @onclick="StartRenameFromMenu">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                        Rename
                    </button>
                    <div class="h-px bg-slate-200 dark:bg-slate-700 my-1"></div>
                    @if (SectionWidget.ParentWidgetId is not null)
                    {
                        <button class="w-full flex items-center gap-2 px-3 py-2 text-sm text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
                                @onclick="RemoveFromSection">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                            Remove from Section
                        </button>
                        <div class="h-px bg-slate-200 dark:bg-slate-700 my-1"></div>
                    }
                    <button class="w-full flex items-center gap-2 px-3 py-2 text-sm text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-950 transition-colors"
                            @onclick="DeleteSection">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3,6 5,6 21,6"/><path d="M19,6l-1,14a2,2,0,0,1-2,2H8a2,2,0,0,1-2-2L5,6"/><path d="M10,11v6"/><path d="M14,11v6"/><path d="M9,6V4a1,1,0,0,1,1-1h4a1,1,0,0,1,1,1V6"/></svg>
                        Delete Section
                    </button>
                </div>
            }
        </div>
    </div>

    <!-- Section content -->
    @if (!IsCollapsed)
    {
        <div class="p-4 bg-white dark:bg-slate-800 rounded-b-xl">
            <div class="@LayoutClass gap-6">
                @foreach (var widget in ChildWidgets.OrderBy(w => w.Order))
                {
                    @if (widget.Type == WidgetType.Section)
                    {
                        <!-- Nested section - render recursively but it won't allow further nesting -->
                        <div class="col-span-full">
                            <WidgetSection SectionWidget="@widget" AllWidgets="@AllWidgets" LayoutClass="@LayoutClass" />
                        </div>
                    }
                    else
                    {
                        <WidgetBase Widget="@widget">
                            <WidgetContent Widget="@widget" />
                        </WidgetBase>
                    }
                }

                @* Drop zone placeholder when dragging *@
                @if (_isDragOver && ChildWidgets.Count() == 0)
                {
                    <div class="min-h-[100px] border-2 border-dashed border-blue-400 rounded-xl flex items-center justify-center text-blue-500 dark:text-blue-400 bg-blue-50 dark:bg-blue-950/30">
                        <span class="text-sm">Drop widget here</span>
                    </div>
                }
            </div>
        </div>
    }
    else if (_isDragOver)
    {
        <div class="p-4 bg-white dark:bg-slate-800 rounded-b-xl">
            <div class="min-h-[60px] border-2 border-dashed border-blue-400 rounded-xl flex items-center justify-center text-blue-500 dark:text-blue-400 bg-blue-50 dark:bg-blue-950/30">
                <span class="text-sm">Drop to add to section</span>
            </div>
        </div>
    }
</div>

@code {
    /// <summary>The section widget (Type == "section").</summary>
    [Parameter, EditorRequired] public Widget SectionWidget { get; set; } = default!;

    /// <summary>All widgets in the dashboard - child widgets will be filtered by ParentWidgetId.</summary>
    [Parameter] public IEnumerable<Widget> AllWidgets { get; set; } = [];

    [Parameter] public string LayoutClass { get; set; } = "grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 auto-rows-min";

    /// <summary>Optional search query to filter child widgets.</summary>
    [Parameter] public string? SearchQuery { get; set; }

    [Inject] private IDashboardService DashboardService { get; set; } = default!;

    private bool _isDragOver;
    private bool _isHovered;
    private bool _menuOpen;
    private bool _renaming;
    private string _renameValue = "";
    private ElementReference _renameInput;

    private IEnumerable<Widget> ChildWidgets
    {
        get
        {
            var children = AllWidgets.Where(w => w.ParentWidgetId == SectionWidget.Id);

            if (string.IsNullOrWhiteSpace(SearchQuery))
                return children;

            // Filter children by search query
            return children.Where(w => 
                w.Title.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase) ||
                w.Type.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase));
        }
    }

    private bool IsCollapsed => SectionWidget.GetConfig("collapsed", false);

    /// <summary>Whether this section is nested inside another section.</summary>
    private bool IsNested => SectionWidget.ParentWidgetId is not null;

    private void OnDragEnd()
    {
        // Clear drag state in JS when drag ends
        _ = JS.InvokeVoidAsync("dragDropInterop.clearDragState");
    }

    private string GetContainerClass()
    {
        var classes = new List<string>();

        if (_isDragOver)
            classes.Add("ring-2 ring-blue-500 ring-offset-2");

        if (IsNested)
            classes.Add("border-slate-300 dark:border-slate-600 bg-slate-50 dark:bg-slate-850");
        else
            classes.Add("border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800");

        return string.Join(" ", classes);
    }

    private void ToggleMenu() => _menuOpen = !_menuOpen;

    private async Task ToggleCollapse()
    {
        var collapsed = !IsCollapsed;
        SectionWidget.Config["collapsed"] = collapsed;
        await DashboardService.SaveWidgetAsync(SectionWidget);
    }

    private async Task OnDragStart()
    {
        // Check if drag was initiated from the handle (via JS)
        var allowed = await JS.InvokeAsync<bool>("dragDropInterop.onDragStart", SectionWidget.Id);
        // If not allowed, the widget ID won't be set and drop handlers will ignore it
    }

    private async Task OnDragEnter()
    {
        // Check if the dragged widget is not this section itself
        var draggedId = await JS.InvokeAsync<string?>("dragDropInterop.getDraggedWidgetId");
        if (draggedId != SectionWidget.Id)
        {
            // Only allow dropping into this section if it won't exceed nesting limit
            // A section can accept drops if it's top-level OR if the dragged item is not a section
            var draggedWidget = AllWidgets.FirstOrDefault(w => w.Id == draggedId);
            if (draggedWidget is not null)
            {
                // If this section is already nested, don't allow sections to be dropped here
                if (IsNested && draggedWidget.Type == WidgetType.Section)
                    return;

                _isDragOver = true;
            }
        }
    }

    private void OnDragLeave()
    {
        _isDragOver = false;
    }

    private async Task OnDrop()
    {
        _isDragOver = false;
        var draggedId = await JS.InvokeAsync<string?>("dragDropInterop.getDraggedWidgetId");
        await JS.InvokeVoidAsync("dragDropInterop.clearDragState");

        if (!string.IsNullOrEmpty(draggedId) && draggedId != SectionWidget.Id)
        {
            // Move the dragged widget into this section
            await DashboardService.MoveWidgetToSectionAsync(draggedId, SectionWidget.Id);
        }
    }

    private async Task RemoveFromSection()
    {
        await DashboardService.MoveWidgetToSectionAsync(SectionWidget.Id, null);
        Toast.ShowSuccess("Section moved to top level");
        _menuOpen = false;
    }

    private async Task DeleteSection()
    {
        await DashboardService.DeleteWidgetAsync(SectionWidget.Id);
        Toast.ShowSuccess("Section deleted");
        _menuOpen = false;
    }

    private bool _shouldFocusRename;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_shouldFocusRename)
        {
            _shouldFocusRename = false;
            try { await _renameInput.FocusAsync(); } catch { }
        }
    }

    private void StartRename()
    {
        _renameValue = SectionWidget.Title;
        _renaming = true;
        _shouldFocusRename = true;
    }

    private void StartRenameFromMenu()
    {
        _menuOpen = false;
        StartRename();
    }

    private async Task FocusRenameInputAsync()
    {
        await Task.Yield();
        try { await _renameInput.FocusAsync(); } catch { }
    }

    private async Task CommitRename()
    {
        _renaming = false;
        var name = _renameValue.Trim();
        if (string.IsNullOrWhiteSpace(name) || name == SectionWidget.Title) return;
        SectionWidget.Title = name;
        await DashboardService.SaveWidgetAsync(SectionWidget);
        Toast.ShowSuccess($"Renamed to \"{name}\"");
    }

    private async Task OnRenameKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")        await CommitRename();
        else if (e.Key == "Escape") { _renaming = false; }
    }
}
